OPENAI_API_KEY=your_api_key

# Database Configuration
# Set USE_REAL_DB=true to connect to PostgreSQL, false for mock data
USE_REAL_DB=false
DB_HOST=localhost
DB_PORT=5432
DB_NAME=voice_automation
DB_USER=postgres
DB_PASSWORD=

# Redis Configuration
# Set USE_REAL_REDIS=true to connect to Redis, false for mock cache
USE_REAL_REDIS=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Server Configuration
PORT=5050
TEMPERATURE=0.8